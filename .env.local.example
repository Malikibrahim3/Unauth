# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=  # optional alias for ANON key
SUPABASE_SERVICE_ROLE_KEY=         # server only, never client

# Identity hashing
IDENTITY_SALT=                      # 64+ random hex chars; rotate via migration

# App
# Set this to the port your local `next dev` is actually using.
# If 3000 is busy, Next may fall back to 3001, 3002, etc.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Amplitude — Get from Amplitude dashboard — create free account at amplitude.com
NEXT_PUBLIC_AMPLITUDE_API_KEY=
