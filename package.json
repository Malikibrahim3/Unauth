{
  "name": "parcelclaim",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest --passWithNoTests",
    "eval": "ts-node --transpile-only --compiler-options '{\"module\":\"commonjs\",\"moduleResolution\":\"node\"}' scripts/eval.ts",
    "snapshot-metrics": "ts-node --transpile-only --compiler-options '{\"module\":\"commonjs\",\"moduleResolution\":\"node\"}' scripts/snapshot-network-metrics.ts",
    "test:watch": "jest --watch",
    "generate:blind-csvs": "ts-node --transpile-only --compiler-options '{\"module\":\"commonjs\",\"moduleResolution\":\"node\"}' scripts/test-data/generateBlindMerchantCSVs.ts",
    "test:csv-blind": "npm run generate:blind-csvs && jest tests/identity --runInBand",
    "test:identity": "jest tests/identity --runInBand",
    "test:merchant-readiness": "npm run test:csv-blind",
    "diagnose:audit-rls": "ts-node --transpile-only --compiler-options '{\"module\":\"commonjs\",\"moduleResolution\":\"node\"}' scripts/test-data/diagnoseAuditRls.ts",
    "ux:screenshots": "rm -rf .next && playwright test --config=tests/ux-audit/playwright.config.ts",
    "ux:audit": "npm run ux:screenshots && node scripts/generate-ux-audit-report.mjs",
    "audit:deployment": "npm run audit:csv && npm run audit:identity && npm run audit:security",
    "audit:ux": "node scripts/deployment-readiness/audit-ux-playwright.mjs",
    "audit:csv": "ts-node --transpile-only --compiler-options '{\"module\":\"commonjs\",\"moduleResolution\":\"node\"}' scripts/deployment-readiness/run-benchmarks.ts",
    "audit:identity": "node scripts/deployment-readiness/audit-identity.mjs",
    "audit:security": "node scripts/deployment-readiness/audit-security.mjs"
  },
  "dependencies": {
    "@amplitude/analytics-browser": "^2.42.0",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.39.8",
    "@tailwindcss/postcss": "^4.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "next": "^16.2.4",
    "papaparse": "^5.4.1",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/papaparse": "^5.3.14",
    "@types/pg": "^8.11.10",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "glob": "^13.0.6",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "pg": "^8.20.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
